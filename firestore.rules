rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: leads
    // Fields: uid, name, email, phone, status, score, source, intent, createdAt, lastInteraction
    //
    // Collection: appointments
    // Fields: uid, leadId, scheduledAt, type, notes, createdAt
    //
    // Collection: leads/{leadId}/messages
    // Fields: leadId, role, content, timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "youngslim4985@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidLead(data) {
      return data.uid is string &&
             data.status in ["INITIAL", "QUALIFYING", "CONTACT_COLLECTION", "SCHEDULING", "FOLLOW_UP"] &&
             data.score in ["HOT", "WARM", "COLD"] &&
             data.source in ["WEB", "FB", "IG"] &&
             data.createdAt is string;
    }

    function isValidAppointment(data) {
      return data.uid is string &&
             data.leadId is string &&
             data.scheduledAt is string &&
             data.createdAt is string;
    }

    function isValidMessage(data) {
      return data.leadId is string &&
             data.role in ["user", "model"] &&
             data.content is string &&
             data.timestamp is string;
    }

    // Rules
    match /leads/{leadId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidLead(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidLead(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.uid) || isAdmin();
        allow create: if isOwner(get(/databases/$(database)/documents/leads/$(leadId)).data.uid) && isValidMessage(request.resource.data);
      }
    }

    match /appointments/{appointmentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidAppointment(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidAppointment(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin();
    }
  }
}
